generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  ACTIVE
  INACTIVE
}

enum AssignmentStatus {
  ASSIGNED
  RETURNED
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
}



enum DeviceState {
  AVAILABLE
  ASSIGNED
  REPAIR
  REPAIRING
  RETIRED
}

enum NotificationType {
  DEVICE_ASSIGN
  DEVICE_CREATE
  REPAIR
  WARRANTY
  USER_CREATE
  DEVICE_RETURN
}

model User {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  username String @unique
  email    String @unique(map: "user_email_idx")

  firstName String
  lastName  String

  emailVerified DateTime?
  password      String

  roleId String @db.Uuid

  accounts Account[]
  sessions Session[]

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
}

model Account {
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
}

model Role {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String @unique(map: "role_name_idx")
  description String
  status      Status @default(ACTIVE)

  user      User[]
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  roleModules RoleModule[]
}

model Module {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String @unique(map: "module_name_idx")
  description String
  route       String @unique
  status      Status @default(ACTIVE)

  roleModules RoleModule[]

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
}

model RoleModule {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  roleId   String @db.Uuid
  moduleId String @db.Uuid

  canView   Boolean @default(true)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId])
}

model Asset {
  id           String  @id @default(uuid()) @db.Uuid
  name         String
  serialNumber String?
  assetState   String  @default("AVAILABLE")

  brand         String?
  model         String?
  configuration String?

  purchaseDate  DateTime?
  purchaseValue Float?
  invoiceNumber String?
  vendor        String?

  hasWarranty Boolean @default(false)
  condition   String?
  remarks     String?

  warrantyStartDate DateTime?
  warrantyEndDate   DateTime?
  warrantyDuration  Int?
  warrantyProvider  String?
  warrantyType      String?

  accessories    Accessory[]
  assignedAssets AssignedAsset[]
  notifications  Notification[]

  assetTypeId String?
  assetType   AssetType? @relation(fields: [assetTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Accessory {
  id String @id @default(uuid()) @db.Uuid

  accessoryTypeId String?
  accessoryType   AccessoryType? @relation(fields: [accessoryTypeId], references: [id])

  make      String?
  model     String?
  serialNo  String?
  condition String

  assetId String @db.Uuid
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AccessoryType {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accessories Accessory[] // ✅ FIXED
}

model AssetType {
  id          String    @id @default(cuid())
  name        String
  description String? // ✅ ADD THIS
  status      Status    @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  assets Asset[]
}

model AssignedAsset {
  id String @id @default(uuid()) @db.Uuid

  assetId    String @db.Uuid
  employeeId String @db.Uuid

  asset    Asset    @relation(fields: [assetId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  status AssignmentStatus @default(ASSIGNED)

  assignedAt DateTime  @default(now())
  returnedAt DateTime?

  remarks String? // ✅ ADD THIS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  name String @unique(map: "department_name_idx")
  code String @unique(map: "department_code_idx") // ✅ ADD THIS

  description String
  status      Status @default(ACTIVE)

  employee Employee[]

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  @@index([status])
  @@index([code])
}

model Location {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String  @unique(map: "location_name_idx")
  code              String  @unique(map: "location_code_idx")
  address           String
  city              String
  state             String
  country           String
  pincode           String
  hasMultipleFloors Boolean @default(false)
  status            Status  @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([city])
  @@index([code])
}

model FrontClient {
  id            String @id @default(cuid())
  name          String
  frontClientId String @unique
  contactPerson String
  contactNumber String
  contactEmail  String
  gstNumber     String
  panNumber     String
  address       String
  country       String
  pincode       String
  city          String
  state         String
  status        String @default("Active")

  endClients EndClient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EndClient {
  id          String @id @default(cuid())
  name        String
  endClientId String @unique

  frontClientId  String  

  frontClient    FrontClient @relation(fields: [frontClientId],references: [id], onDelete: Cascade)

  contactPerson String
  contactNumber String
  contactEmail  String

  status String @default("Active")

  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id      String           @id @default(uuid())
  title   String
  message String
  type    NotificationType // ✅ must use enum
  isRead  Boolean          @default(false)

  triggerDay Int?

  assetId String? @db.Uuid
  asset   Asset?  @relation(fields: [assetId], references: [id])

  createdAt DateTime @default(now())
}

model Employee {
  id          String    @id @default(uuid()) @db.Uuid
  first_name  String
  last_name   String    @unique
  email       String?
  phoneNumber String?
  dateOfBirth DateTime?
  hireDate    DateTime?

  status Status @default(ACTIVE)

  departmentId String     @db.Uuid
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  designationId String?      @db.Uuid
  designation   Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedAssets AssignedAsset[]
  purchaseOrders PurchaseOrder[]

  @@index([departmentId])
  @@index([status])
}

model Designation {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  name String @unique(map: "designation_name_idx")
  code String @unique(map: "designation_code_idx")

  level       Int
  description String

  status Status @default(ACTIVE)

  employee Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([code])
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  endClientId   String
  employeeId    String   @db.Uuid 

  poNumber      String
  contactName   String?
  contactNumber String?
  contactEmail  String?

  startDate     DateTime
  endDate       DateTime
  poReceiveDate DateTime

  poType        String
  status        String
  poValue       Float

  createdAt     DateTime @default(now())

  endClient EndClient @relation(fields: [endClientId], references: [id])
  employee  Employee  @relation(fields: [employeeId], references: [id])
}


model Configuration {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name    String?
  logo    String?
  favicon String?

  smtpHost     String
  smtpPort     Int
  smtpUser     String
  smtpPassword String
  fromEmail    String
}

