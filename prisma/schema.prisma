generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Status {
  ACTIVE
  INACTIVE
}

enum AssignmentStatus {
  ASSIGNED
  RETURNED
}

enum DeviceStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
}

enum VendorStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum QuotationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DeviceState {
  AVAILABLE
  ASSIGNED
  REPAIR
  REPAIRING
  RETIRED
}

enum NotificationType {
  DEVICE_ASSIGN
  DEVICE_CREATE
  REPAIR
  WARRANTY
  USER_CREATE
  DEVICE_RETURN
}

model User {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  username String @unique
  email    String @unique(map: "user_email_idx")

  firstName String
  lastName  String

  emailVerified DateTime?
  password      String

  roleId String @db.Uuid

  accounts Account[]
  sessions Session[]

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
}

model Account {
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @id
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
}

model Role {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String @unique(map: "role_name_idx")
  description String
  status      Status @default(ACTIVE)

  user      User[]
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  roleModules RoleModule[]
}

model Module {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String @unique(map: "module_name_idx")
  description String
  route       String @unique
  status      Status @default(ACTIVE)

  roleModules RoleModule[]

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
}

model RoleModule {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  roleId   String @db.Uuid
  moduleId String @db.Uuid

  canView   Boolean @default(true)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId])
}

model Asset {
  id String @id @default(uuid()) @db.Uuid
  name         String
  serialNumber String?

  brand         String?
  model         String?
  configuration String?

  purchaseDate  DateTime?
  purchaseValue Float?
  invoiceNumber String?
  vendor        String?

  hasWarranty Boolean @default(false)
  condition   String?
  remarks     String?

  warrantyStartDate DateTime?
  warrantyEndDate   DateTime?
  warrantyDuration  Int?
  warrantyProvider  String?
  warrantyType      String?

  accessories   Accessory[]
  assignedAssets AssignedAsset[]
  notifications Notification[]

  assetTypeId String?
  assetType   AssetType? @relation(fields: [assetTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Accessory {
  id String @id @default(uuid()) @db.Uuid

  accessoryTypeId String?
  accessoryType   AccessoryType? @relation(fields: [accessoryTypeId], references: [id])

  make      String?
  model     String?
  serialNo  String?
  condition String

  assetId String @db.Uuid
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AccessoryType {
  id          String   @id @default(cuid())
  name        String
  description String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accessories Accessory[] // ✅ FIXED
}

model AssetType {
  id          String    @id @default(cuid())
  name        String
  description String? // ✅ ADD THIS
  status      Status    @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt

  assets Asset[]
}

model AssignedAsset {
  id          String   @id @default(uuid()) @db.Uuid

  assetId     String   @db.Uuid   
  employeeId  String   @db.Uuid

  asset       Asset    @relation(fields: [assetId], references: [id])
  employee    Employee @relation(fields: [employeeId], references: [id])

  status      AssignmentStatus @default(ASSIGNED)
  assignedAt  DateTime @default(now())
  returnedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  name String @unique(map: "department_name_idx")
  code String @unique(map: "department_code_idx") // ✅ ADD THIS

  description String
  status      Status @default(ACTIVE)

  employee Employee[]

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  @@index([status])
  @@index([code])
}

model Location {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String  @unique(map: "location_name_idx")
  code              String  @unique(map: "location_code_idx")
  address           String
  city              String
  state             String
  country           String
  pincode           String
  hasMultipleFloors Boolean @default(false)
  status            Status  @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([city])
  @@index([code])
}

model Notification {
  id      String           @id @default(uuid())
  title   String
  message String
  type    NotificationType // ✅ must use enum
  isRead  Boolean          @default(false)

  triggerDay Int?

  assetId String? @db.Uuid
  asset   Asset?  @relation(fields: [assetId], references: [id])

  createdAt DateTime @default(now())
}

model Employee {
  id String @id @default(uuid()) @db.Uuid
  first_name  String
  last_name   String    @unique
  email       String?
  phoneNumber String?
  dateOfBirth DateTime?
  hireDate    DateTime?

  status Status @default(ACTIVE)

  departmentId String     @db.Uuid
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  designationId String?      @db.Uuid
  designation   Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedAssets AssignedAsset[]

  @@index([departmentId])
  @@index([status])
}

model Designation {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  name String @unique(map: "designation_name_idx")
  code String @unique(map: "designation_code_idx")

  level       Int
  description String

  status Status @default(ACTIVE)

  employee Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([code])
}

model Vendor {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vendorCode     String          @unique
  purchaseOrders PurchaseOrder[]
  quotations     Quotation[]
  name           String
  contactPerson  String?
  phone          String?
  email          String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  state          String?
  postalCode     String?
  country        String?
  taxId          String?
  website        String?
  status         VendorStatus    @default(ACTIVE)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Requirement {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  manufatured       String
  purchaseOrders    PurchaseOrder[]
  quotations        Quotation[]
  model             String
  configuration     Json?
  warranty          String
  notes             String?
  vendorIds         String[]
  warrantyType      String?
  quotationValidity DateTime        @db.Timestamp(6)
  createdAt         DateTime        @default(now()) @db.Timestamp(6)
  updatedAt         DateTime        @updatedAt
  status            Status          @default(ACTIVE)
}

model Procurement {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  manufatured       String
  model             String
  configuration     Json?
  warranty          String
  notes             String?
  vendorId          String
  warrantyType      String?
  quotationValidity DateTime @db.Timestamp(6)
  createdAt         DateTime @default(now()) @db.Timestamp(6)
  updatedAt         DateTime @updatedAt
  status            Status   @default(ACTIVE)
  requirementId     String
}

model Configuration {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name    String?
  logo    String?
  favicon String?

  smtpHost     String
  smtpPort     Int
  smtpUser     String
  smtpPassword String
  fromEmail    String
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  APPROVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  poNumber      String              @unique
  requirementId String              @db.Uuid
  vendorId      String              @db.Uuid
  status        PurchaseOrderStatus @default(DRAFT)
  totalAmount   Float

  requirement Requirement         @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  vendor      Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  items       PurchaseOrderItem[]

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)

  @@index([requirementId])
  @@index([vendorId])
  @@index([status])
}

model PurchaseOrderItem {
  id               String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  purchaseOrderId  String @db.Uuid
  deviceCategoryId String @db.Uuid
  quantity         Int
  unitPrice        Float
  totalPrice       Float

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([deviceCategoryId])
}

model Quotation {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  vendorId      String @db.Uuid
  requirementId String @db.Uuid

  items             Json
  validTill         DateTime
  deliveryDays      Int
  paymentTerms      String
  gst               Float
  additionalCharges Float
  subtotal          Float
  gstAmount         Float
  grandTotal        Float
  remarks           String?

  status QuotationStatus @default(PENDING)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  vendor      Vendor      @relation(fields: [vendorId], references: [id])
  requirement Requirement @relation(fields: [requirementId], references: [id])

  @@index([vendorId])
  @@index([requirementId])
}
